<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Modules et Sessions</title>
		<link rel="stylesheet" href="{{ asset('css/sessionmodule.css') }}">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
	</head>

	<body class="modern-layout">

		{% include 'haut_de_page/haut_de_page.html.twig' %}


		<section class="form_creations">
			{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}

				
				{% set currentUser = app.user %}
				{% for utilisateur in utilisateurs %}
					{% if utilisateur.id == currentUser.id %}

						<div class="subscription-message">
							<h1 class="section-title-pricipale">
								Partie Administration
							</h1>

							<p>Type d'abonnement: 
								<span class="subscription-badge {{ currentUser.subscriptionType|lower }}">
									{{ utilisateur.subscriptionType ?? 'Aucun' }}
								</span>
							</p>
							{% if currentUser.subscriptionType == 'premium' %}
								<p>Institutions créées: {{ utilisateur.nombreInstitutions }}</p>
							{% endif %}

							</br>

							{% if currentUser.subscriptionType == 'basique' %}
								<p class="info-text">Abonnement basique - Jusqu'à 1 000 utilisateurs</p>
							{% endif %}
							{% if currentUser.subscriptionType == 'premium' %}
								<p class="info-text premium-text">Abonnement premium - Jusqu'à 10 000 utilisateurs</p>
							{% endif %}
						</div>

						<div class="table-container">
							<table class="table">
								<thead>
									<tr>
										<th>Nom de l'institution</th>
										<th>Nombre d'utilisateurs</th>
									</tr>
								</thead>
								<tbody>
									{% for stat in stats %}
										<tr>
											<td>{{ stat.institution_nom }}</td>
											<td>{{ stat.user_count }}</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				{% endfor %}
			{% endif %}
		</section>


		<div class="form_creations">

		{% for message in app.flashes('success') %}
			<div class="alert alert-success">
				<i class="material-icons-round">check_circle</i>
				{{ message }}
			</div>
		{% endfor %}



			{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}

				<section class="form-section">

					<h2 class="section-title">
						<i class="material-icons-round">group_add</i>
						Créer une nouvelle Institution
					</h2>

						{% if currentUser.subscriptionType == 'basique' %}
							Passez à un abonnement premium pour créer plusieurs Institutions
						{% else %}
						{% if currentUser and currentUser.nombreInstitutions < 5 %}


							<div class="form-container">
								{{ form_start(formInstitution) }}
								<div class="form-grid">
									<div class="form-group">
										{{ form_row(formInstitution.nom, {
										'attr': {'class': 'form-input'}
									}) }}
									</div>
									<div class="form-group">
										{{ form_row(formInstitution.adresse, {
										'attr': {'class': 'form-input'}
									}) }}
									</div>
									<div class="form-group">
										{{ form_row(formInstitution.telephone, {
										'attr': {'class': 'form-input'}
									}) }}
									</div>
									<div class="form-group">
										{{ form_row(formInstitution.courriel, {
										'attr': {'class': 'form-input'}
									}) }}
									</div>
									<div class="form-submit">
										<button type="submit" class="submit-btn">
											<i class="material-icons-round">add_circle</i>
											Créer Institution
										</button>
									</div>
								</div>


								{{ form_end(formInstitution) }}
							</div>
						{% else %}
							<div class="alert alert-warning">
								Vous avez atteint la limite de 5 institutions. 
							</div>
						{% endif %}
					{% endif %}
					</section>
				
			{% endif %}


			<!-- FORM CREATION SESSION -->

			<!-- User Association Form (Admin/Teacher) -->

			{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
				<section class="form-section">
					<h2 class="section-title">
						<i class="material-icons-round">group_add</i>
						Créer une nouvelle session
					</h2>
					<div class="form-container">
						{{ form_start(formSession) }}
						<div class="form-grid">
							<div class="form-group">
								{{ form_row(formSession.nom, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formSession.type, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formSession.date_debut, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formSession.date_fin, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formSession.description, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-submit">
								<button type="submit" class="submit-btn">
									<i class="material-icons-round">add_circle</i>
									Créer Session
								</button>
							</div>
						</div>

						{{ form_end(formSession) }}
					</div>
				</section>
			{% endif %}



			{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
				<section class="form-section">
					<h2 class="section-title">
						<i class="material-icons-round">group_add</i>
						Créer un nouveau module
					</h2>
					<div class="form-container">
						{{ form_start(formModule) }}
						<div class="form-grid">
							<div class="form-group">
								{{ form_row(formModule.nom, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formModule.description, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formModule.commentaire, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formModule.date_debut, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>
							<div class="form-group">
								{{ form_row(formModule.date_fin, {
                                    'attr': {'class': 'form-input'}
                                }) }}
							</div>


							<div class="form-submit">
								<button type="submit" class="submit-btn">
									<i class="material-icons-round">add_circle</i>
									Créer Module
								</button>
							</div>

							{{ form_end(formModule) }}
						</div>
					</section>
				{% endif %}






				<!-- Formulaire Horaires -->
				{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
					<section class="form-section">
						<div class="section-header">
							<h2 class="section-title">
								<i class="material-icons-round">schedule</i>
								Définir les horaires du module
							</h2>
							<p class="section-description">
								Configurez les créneaux horaires pour vos sessions de formation
							</p>
						</div>

						<div class="form-container">
							{{ form_start(formHoraire, {'attr': {'class': 'horaire-form'}}) }}
							<div
								class="form-grid">
								<!-- Champ Session Module -->
								<div class="form-group-row">
									<div class="form-group">
										{{ form_row(formHoraire.UtilisateurInstitutionSessionModule, {
                                    'label': 'Session de Module',
                                    'attr': {
                                        'class': 'form-control session-module-select',
                                        'data-placeholder': 'Sélectionnez une session'
                                    },
                                    'help': 'Choisissez un module associé à une session de formation'
                                }) }}
									</div>
								</div>

								<!-- Jour de la semaine -->
								<div class="form-group-row">
									<div class="form-group">
										{{ form_row(formHoraire.jour, {
                                    'attr': {'class': 'form-control'}
                                }) }}
									</div>
								</div>

								<!-- Date précise -->
								<div class="form-group-row">
									<div class="form-group">
										{{ form_row(formHoraire.datePrecise, {
                                    'attr': {'class': 'form-control datepicker'}
                                }) }}
									</div>
								</div>

								<!-- Heures -->
								<div class="form-group-row time-inputs">
									<div class="form-group">
										{{ form_row(formHoraire.heureDebut, {
                                    'attr': {'class': 'form-control timepicker'}
                                }) }}
									</div>
									<div class="form-group">
										{{ form_row(formHoraire.heureFin, {
                                    'attr': {'class': 'form-control timepicker'}
                                }) }}
									</div>
								</div>
							</div>

							<div class="form-actions">
								<button type="submit" class="btn btn-primary">
									<i class="material-icons-round">save</i>
									Enregistrer les horaires
								</button>
								<button type="reset" class="btn btn-secondary">
									<i class="material-icons-round">refresh</i>
									Réinitialiser
								</button>
							</div>
							{{ form_end(formHoraire) }}
						</div>
					</section>


					<!-- User Association Form (Admin/Teacher) -->
					{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
						<section class="form-section-association">
							<h2 class="section-title">
								<i class="material-icons-round">group_add</i>
								Associer un Module à un Utilisateur

							</h2>
							<div class="form-container-association">
								{{ form_start(formUtilisateurInstitutionSessionModule) }}
								<div class="form-grid-association">
									<div class="form-group">
										{{ form_row(formUtilisateurInstitutionSessionModule.Utilisateur, {
                                    'attr': {'class': 'form-input'}
                                }) }}
									</div>
									<div class="form-group">
										{{ form_row(formUtilisateurInstitutionSessionModule.SessionModule, {
                                    'attr': {'class': 'form-input'}
                                }) }}
									</div>
									<div class="form-submit">
										<button type="submit" class="submit-btn">
											<i class="material-icons-round">add_circle</i>
											Créer association
										</button>
									</div>
								</div>
								{{ form_end(formUtilisateurInstitutionSessionModule) }}
							</div>
						</section>
					{% endif %}


					<!-- Existing Associations Table -->
					<section class="table-section">
						<h2 class="section-title">
							<i class="material-icons-round">list_alt</i>
							Modules suivie par Utilisateur
						</h2>
						<div class="table-responsive">
							<table class="data-table">
								<thead>
									<tr>
										<th>Utilisateur</th>
										<th>Session</th>
										<th>Module</th>
										{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
											<th>Rôles</th>
											<th>Actions</th>
										{% endif %}
									</tr>
								</thead>
								<tbody>
									{% for item in utilisateurInstitutionSessionModules %}
										<tr>
											<td>{{ item.Utilisateur.nom }}
												{{ item.Utilisateur.prenom }}</td>
											<td>{{ item.SessionModule.Session.nom }}</td>
											<td>{{ item.SessionModule.Module.nom }}</td>
											{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
												<td>{{ item.Utilisateur.roles|join(', ') }}</td>
												<td class="actions-cell">
													<a href="{{ path('modifier_utilisateur_institution_session_module', {'id': item.id}) }}" class="action-btn edit">
														<i class="material-icons-round">edit</i>
													</a>
													<form method="POST" action="{{ path('app_Session_Module') }}" class="inline-form">
														<input type="hidden" name="deleteUtilisateurId" value="{{ item.id }}">
														<button type="submit" class="action-btn delete">
															<i class="material-icons-round">delete</i>
														</button>
													</form>
												</td>
											{% endif %}
										</tr>
									{% else %}
										<tr>
											<td colspan="{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}5{% else %}3{% endif %}" class="no-data">
												Aucune association trouvée
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					</section>


					<section class="management-section">


						<h2 class="section-title">
							<i class="material-icons-round">school</i>
							Création des Associations Institutions Sessions et modules
						</h2>

						<!-- Add New Session-Module Form -->
						{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
							<div class="session-module-form-container">
								{{ form_start(form) }}

								<div class="form-group">
									{{ form_label(form.module, 'Module') }}
									{{ form_widget(form.module) }}
									{{ form_errors(form.module, {
                        'attr': {'class': 'module-errors'}
                    }) }}

								</div>

								<div class="form-group">
									{{ form_label(form.session, 'Session') }}
									{{ form_widget(form.session) }}
								</div>

								<div class="form-group">
									{{ form_label(form.institution, 'Institution') }}
									{{ form_widget(form.institution) }}
								</div>

								<button type="submit" class="submit-btn">Enregistrer</button>

								{{ form_end(form) }}
							</div>
						{% endif %}

						<!-- Session-Module Grid -->
						<div class="grid-section"></section>


						<section class="management-section">


							<h2 class="section-title">
								<i class="material-icons-round">list_alt</i>
								Liste des Associations existents Institutions Sessions et modules
							</h2>

							<div class="grid-container">
								{% for result in results %}

									<div class="grid-card">
										<input type="checkbox" id="card-toggle-{{ result.moduleId }}" class="card-toggle">
										<label for="card-toggle-{{ result.moduleId }}" class="card-header">
											<h3 class="card-title">
												<i class="material-icons-round">link</i>
												{{ result.moduleNom }}
												/
												{{ result.sessionNom }}
												/
												{{ result.institutionNom }}
											</h3>
											{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
												<div class="card-actions">
													<a href="{{ path('modifier_session_module', {'id': result.moduleId}) }}" class="action-btn edit">
														<i class="material-icons-round">edit</i>
													</a>
													<form action="{{ path('app_Session_Module') }}" method="get" class="inline-form">
														<input type="hidden" name="delete_id" value="{{ result.moduleId }}">
														<button type="submit" class="action-btn delete">
															<i class="material-icons-round">delete</i>
														</button>
													</form>
												</div>
											{% endif %}
											<span class="expand-icon">
												<i class="material-icons-round">expand_more</i>
											</span>
										</label>

										<div class="card-body">
											<div class="info-block">
												<h4 class="info-title">
													<i class="material-icons-round">account_balance</i>
													Institution
												</h4>
												<p>
													<strong>Nom:</strong>
													{{ result.institutionNom }}</p>
												<p>
													<strong>Adresse:</strong>
													{{ result.institutionAdresse }}</p>
												<p>
													<strong>Contact:</strong>
													{{ result.institutionTelephone }}
													|
													{{ result.institutionCourriel }}</p>
											</div>

											<div class="info-block">
												<h4 class="info-title">
													<i class="material-icons-round">event</i>
													Session
												</h4>
												<p>
													<strong>Période:</strong>
													{{ result.sessionDateDebut|date('d/m/Y') }}
													au
													{{ result.sessionDateFin|date('d/m/Y') }}</p>
												<p>
													<strong>Type:</strong>
													{{ result.sessionType }}</p>
												<p>
													<strong>Description:</strong>
													{{ result.sessionDescription }}</p>
											</div>

											<div class="info-block">
												<h4 class="info-title">
													<i class="material-icons-round">menu_book</i>
													Module
												</h4>
												<p>
													<strong>Nom:</strong>
													{{ result.moduleNom }}</p>
												<p>
													<strong>Description:</strong>
													{{ result.moduleDescription }}</p>
												<p>
													<strong>Période:</strong>
													{{ result.moduleDateDebut|date('d/m/Y') }}
													au
													{{ result.moduleDateFin|date('d/m/Y') }}</p>
											</div>

											<div class="info-block">
												<h4 class="info-title">
													<i class="material-icons-round">people</i>
													Participants
												</h4>
												<div class="participants-list">
													{% for item in utilisateurInstitutionSessionModules %}
														{% if result.moduleNom == item.SessionModule.Module.nom and result.sessionNom == item.SessionModule.Session.nom and result.institutionNom == item.SessionModule.Institution.nom %}
															<div class="participant">
																{{ item.Utilisateur.prenom }}
																<strong>{{ item.Utilisateur.nom }}</strong>
															</div>
														{% endif %}
													{% else %}
														<p class="no-data">Aucun participant</p>
													{% endfor %}
												</div>
											</div>


										</div>
									</div>


								{% endfor %}
							</section>


							<section class="table-section">
								<h2 class="section-title">
									<i class="material-icons-round">list_alt</i>
									Liste des Institutions Sessions et modules existants
								</h2>

								<div
									class="table-responsive">
									<!-- Tableau des Institutions -->
									<div class="table-container">
										<input type="checkbox" id="toggle-institutions" class="table-toggle">
										<label for="toggle-institutions" class="table-header">
											<h3 class="table-subtitle">
												<i class="material-icons-round">account_balance</i>
												Institutions
												<span class="expand-icon">
													<i class="material-icons-round">expand_more</i>
												</span>
											</h3>
										</label>

										<div class="table-body">
											<table>
												<thead>
													<tr>
														<th>Nom de l'Institution</th>
														{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
															<th class="actions-header">Actions</th>
														{% endif %}
													</tr>
												</thead>
												<tbody>
													{% set hasInstitutionData = false %}
													{% for institution in institutions %}
														{% set hasInstitutionData = true %}
														<tr>
															<td>{{ institution.nom }}</td>
															{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
																<td class="actions-cell">
																	<a href="{{ path('institution_modifier', {'id': institution.id}) }}" class="action-btn edit" title="Modifier">
																		<i class="material-icons-round">edit</i>
																	</a>
																	<form method="POST" action="{{ path('app_Session_Module') }}" class="inline-form">
																		<input type="hidden" name="delete_Institution_id" value="{{ institution.id }}">
																		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ institution.id) }}">
																		<button type="submit" class="action-btn delete" title="Supprimer" onclick="return confirm(
																				                                                            'Êtes-vous sûr de vouloir supprimer cette institution ?\n\n' +
																				                                                            '⚠️ Attention ! Cette action est irréversible.\n\n' +
																				                                                            'Toutes les formations associées seront également supprimées.\n' +
																				                                                            'Les utilisateurs inscrits perdront leur accès.\n\n' +
																				                                                            'Cliquez sur OK pour confirmer.'
																				                                                        )">
																			<i class="material-icons-round">delete</i>
																		</button>
																	</form>
																</td>
															{% endif %}
														</tr>
													{% endfor %}

													{% if not hasInstitutionData %}
														<tr>
															<td colspan="{{ is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') ? '2' : '1' }}" class="no-data">
																Aucune institution trouvée
															</td>
														</tr>
													{% endif %}
												</tbody>
											</table>
										</div>
									</div>

									<!-- Tableau des Sessions -->
									<div class="table-container">
										<input type="checkbox" id="toggle-sessions" class="table-toggle">
										<label for="toggle-sessions" class="table-header">
											<h3 class="table-subtitle">
												<i class="material-icons-round">event</i>
												Sessions
												<span class="expand-icon">
													<i class="material-icons-round">expand_more</i>
												</span>
											</h3>
										</label>

										<div class="table-body">
											<table>
												<thead>
													<tr>
														<th>Nom de la Session</th>
														{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
															<th class="actions-header">Actions</th>
														{% endif %}
													</tr>
												</thead>
												<tbody>
													{% set hasSessionData = false %}
													{% for session in sessions %}
														{% set hasSessionData = true %}
														<tr>
															<td>{{ session.nom }}</td>
															{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
																<td class="actions-cell">
																	<a href="{{ path('session_modifier', {'id': session.id}) }}" class="action-btn edit" title="Modifier">
																		<i class="material-icons-round">edit</i>
																	</a>
																	<form method="POST" action="{{ path('app_Session_Module') }}" class="inline-form">
																		<input type="hidden" name="delete_Session_id" value="{{ session.id }}">
																		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ session.id) }}">
																		<button type="submit" class="action-btn delete" title="Supprimer" onclick="return confirm(
																				                                                            'Êtes-vous sûr de vouloir supprimer cette session ?\n\n' +
																				                                                            '⚠️ Attention ! Cette action est irréversible.\n\n' +
																				                                                            'Toutes les formations associées seront également supprimées.\n' +
																				                                                            'Les utilisateurs inscrits perdront leur accès.\n\n' +
																				                                                            'Cliquez sur OK pour confirmer.'
																				                                                        )">
																			<i class="material-icons-round">delete</i>
																		</button>
																	</form>
																</td>
															{% endif %}
														</tr>
													{% endfor %}

													{% if not hasSessionData %}
														<tr>
															<td colspan="{{ is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') ? '2' : '1' }}" class="no-data">
																Aucune session trouvée
															</td>
														</tr>
													{% endif %}
												</tbody>
											</table>
										</div>
									</div>

									<!-- Tableau des Modules -->
									<div class="table-container">
										<input type="checkbox" id="toggle-modules" class="table-toggle">
										<label for="toggle-modules" class="table-header">
											<h3 class="table-subtitle">
												<i class="material-icons-round">menu_book</i>
												Modules
												<span class="expand-icon">
													<i class="material-icons-round">expand_more</i>
												</span>
											</h3>
										</label>

										<div class="table-body">
											<table>
												<thead>
													<tr>
														<th>Nom du Module</th>
														{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
															<th class="actions-header">Actions</th>
														{% endif %}
													</tr>
												</thead>
												<tbody>
													{% set hasModuleData = false %}
													{% for module in modules %}
														{% set hasModuleData = true %}
														<tr>
															<td>{{ module.nom }}</td>
															{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}
																<td class="actions-cell">
																	<a href="{{ path('module_modifier', {'id': module.id}) }}" class="action-btn edit" title="Modifier">
																		<i class="material-icons-round">edit</i>
																	</a>
																	<form method="POST" action="{{ path('app_Session_Module') }}" class="inline-form">
																		<input type="hidden" name="delete_Module_id" value="{{ module.id }}">
																		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ module.id) }}">
																		<button type="submit" class="action-btn delete" title="Supprimer" onclick="return confirm(
																				                                                            'Êtes-vous sûr de vouloir supprimer ce module ?\n\n' +
																				                                                            '⚠️ Attention ! Cette action est irréversible.\n\n' +
																				                                                            'Toutes les formations associées seront également supprimées.\n' +
																				                                                            'Les utilisateurs inscrits perdront leur accès.\n\n' +
																				                                                            'Cliquez sur OK pour confirmer.'
																				                                                        )">
																			<i class="material-icons-round">delete</i>
																		</button>
																	</form>
																</td>
															{% endif %}
														</tr>
													{% endfor %}

													{% if not hasModuleData %}
														<tr>
															<td colspan="{{ is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') ? '2' : '1' }}" class="no-data">
																Aucun module trouvé
															</td>
														</tr>
													{% endif %}
												</tbody>
											</table>
										</div>
									</div>
								</div>
							</section>


						{% endif %}
					</div>


					<!-- Main Content -->
					<main class="content-container">

						<!-- Mes Modules (Nouvelle section ajoutée) -->

						<!-- Mes Modules - Version détaillée -->
							{% if app.user %}
								<section class="my-modules-detailed-section"> <h2 class="section-title">
									<i class="material-icons-round">bookmarks</i>
									Mes Formations
								</h2>

								<div class="detailed-modules-container">
									{% set hasModules = false %}
									{% for item in utilisateurInstitutionSessionModules %}
										{% if item.Utilisateur.id == app.user.id %}
											{% set hasModules = true %}
											<div class="detailed-module-card">
												<div class="module-header">
													<h3 class="module-title">
														<i class="material-icons-round">school</i>
														{{ item.SessionModule.Module.nom }}
													</h3>
												</div>

												<div
													class="module-grid">
													<!-- Colonne Module -->
													<div class="module-info-section">
														<h4 class="info-section-title">
															<i class="material-icons-round">menu_book</i>
															Détails du Module
														</h4>
														<div class="info-content">
															<p>
																<strong>Description :</strong>
																{{ item.SessionModule.Module.description }}</p>
															<p>
																<strong>Période:</strong>
																{{ item.SessionModule.Module.dateDebut|date('d/m/Y') }}
																au
																{{ item.SessionModule.Module.dateFin|date('d/m/Y') }}</p>
														</div>
													</div>

													<!-- Colonne Session -->
													<div class="session-info-section">
														<h4 class="info-section-title">
															<i class="material-icons-round">event</i>
															Détails de la Session
														</h4>
														<div class="info-content">
															<p>
																<strong>Nom :</strong>
																{{ item.SessionModule.Session.nom }}</p>
															<p>
																<strong>Période :</strong>
																Du
																{{ item.SessionModule.Session.dateDebut|date('d/m/Y') }}
																au
																{{ item.SessionModule.Session.dateFin|date('d/m/Y') }}</p>
															<p>
																<strong>Type :</strong>
																{{ item.SessionModule.Session.type }}</p>
															<p>
																<strong>Description :</strong>
																{{ item.SessionModule.Session.description }}</p>
														</div>
													</div>

													<!-- Colonne Institution -->
													<div class="institution-info-section">
														<h4 class="info-section-title">
															<i class="material-icons-round">account_balance</i>
															Centre de Formation
														</h4>
														<div class="info-content">
															<p>
																<strong>Nom :</strong>
																{{ item.SessionModule.Institution.nom }}</p>
															<p>
																<strong>Adresse :</strong>
																{{ item.SessionModule.Institution.adresse }}</p>
															<p>
																<strong>Téléphone :</strong>
																{{ item.SessionModule.Institution.telephone }}</p>
															<p>
																<strong>Email :</strong>
																{{ item.SessionModule.Institution.courriel }}</p>
														</div>
													</div>
												</div>


											</div>
										{% endif %}
									{% endfor %}

									{% if not hasModules %}
										<div class="no-modules-message">
											<i class="material-icons-round">info_outline</i>
											<p>Vous n'êtes actuellement inscrit à aucune formation.</p>
											<a href="#" class="browse-link">Parcourir les formations disponibles</a>
										</div>
									{% endif %}
								</div>
							</section>
						{% endif %}


						<section class="associations-section">
							<h2 class="associations-title">
								<i class="material-icons-round">link</i>
								Liste des Associations existantes Institutions Sessions et modules
							</h2>

							<div class="associations-grid">
								{% for result in results %}
									<div class="association-card">
										<input type="checkbox" id="association-toggle-{{ loop.index }}" class="association-toggle">
										<label for="association-toggle-{{ loop.index }}" class="association-header">
											<h3 class="association-title">
												<i class="material-icons-round">link</i>
												{{ result.moduleNom }}
												/
												{{ result.sessionNom }}
												/
												{{ result.institutionNom }}
											</h3>
											<span class="association-expand-icon">
												<i class="material-icons-round">expand_more</i>
											</span>
										</label>

										<div class="association-content">
											<div class="institution-block">
												<h4 class="block-title">
													<i class="material-icons-round">account_balance</i>
													Institution
												</h4>
												<p>
													<strong>Nom:</strong>
													{{ result.institutionNom }}</p>
												<p>
													<strong>Adresse:</strong>
													{{ result.institutionAdresse }}</p>
												<p>
													<strong>Contact:</strong>
													{{ result.institutionTelephone }}
													|
													{{ result.institutionCourriel }}</p>
											</div>

											<div class="session-block">
												<h4 class="block-title">
													<i class="material-icons-round">event</i>
													Session
												</h4>
												<p>
													<strong>Période:</strong>
													{{ result.sessionDateDebut|date('d/m/Y') }}
													au
													{{ result.sessionDateFin|date('d/m/Y') }}</p>
												<p>
													<strong>Type:</strong>
													{{ result.sessionType }}</p>
												<p>
													<strong>Description:</strong>
													{{ result.sessionDescription }}</p>
											</div>

											<div class="module-block">
												<h4 class="block-title">
													<i class="material-icons-round">menu_book</i>
													Module
												</h4>
												<p>
													<strong>Nom:</strong>
													{{ result.moduleNom }}</p>
												<p>
													<strong>Description:</strong>
													{{ result.moduleDescription }}</p>
												<p>
													<strong>Période:</strong>
													{{ result.moduleDateDebut|date('d/m/Y') }}
													au
													{{ result.moduleDateFin|date('d/m/Y') }}</p>
											</div>

											<div class="participants-block">

												{% if is_granted('ROLE_SUPERADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ENSEIGNANT') %}

													<h4 class="block-title">
														<i class="material-icons-round">people</i>
														Participants
													</h4>
													<div class="participants-container">
														{% for item in utilisateurInstitutionSessionModules %}
															{% if result.moduleNom == item.SessionModule.Module.nom and result.sessionNom == item.SessionModule.Session.nom and result.institutionNom == item.SessionModule.Institution.nom %}
																<div class="participant-item">
																	{{ item.Utilisateur.prenom }}
																	<strong>{{ item.Utilisateur.nom }}</strong>
																</div>
															{% endif %}
														{% else %}
															<p class="empty-participants">Aucun participant</p>
														{% endfor %}
													</div>
												
												{% endif %}
											</div>
										</div>
									</div>
								{% endfor %}
							</div>
						</section>


					</main>


				</body>
			</html>
